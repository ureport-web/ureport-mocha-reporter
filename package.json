{
  "name": "ureport-mocha-reporter",
  "version": "1.0.0",
  "description": "Mocha reporter plugin for UReport — ships test results automatically (also works with Cypress)",
  "main": "dist/cjs/mocha.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json && node scripts/postbuild.js",
    "test": "node_modules/.bin/jest --testPathPattern='tests/(?!integration)'",
    "test:unit": "node_modules/.bin/jest --testPathPattern='tests/(?!integration)'",
    "test:integration": "node_modules/.bin/jest --testPathPattern='tests/integration'",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "mocha",
    "cypress",
    "reporter",
    "ureport",
    "testing"
  ],
  "author": "yizhongji@gmail.com",
  "license": "MIT",
  "peerDependencies": {
    "mocha": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "mocha": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^18.0.0",
    "jest": "^29.5.0",
    "mocha": "^10.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node"
          }
        }
      ]
    }
  },
  "engines": {
    "node": ">=18"
  }
}
